// Prisma Schema for FlashCards App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Flashcard {
  id                    String   @id @default(uuid())
  englishWord           String   @map("english_word")
  indonesianTranslation String   @map("indonesian_translation")
  cefrLevel             CEFRLevel @map("cefr_level")
  partOfSpeech          String?  @map("part_of_speech")
  exampleSentenceEn     String?  @map("example_sentence_en")
  exampleSentenceId     String?  @map("example_sentence_id")
  conversationContext   String?  @map("conversation_context")
  pronunciationGuide    String?  @map("pronunciation_guide")
  frequencyRank         Int?     @map("frequency_rank")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([cefrLevel])
  @@index([frequencyRank])
  @@map("flashcards")
}

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
  C2

  @@map("cefr_level")
}

model Census {
  id                    String   @id @default(uuid())
  no                    String?
  desa                  String?
  kelompok              String?
  nama                  String?
  tempatLahir           String?  @map("tempat_lahir")
  tglLahir              String?  @map("tgl_lahir")
  usiaSekarang          Int?     @map("usia_sekarang")
  jenisKelamin          String?  @map("jenis_kelamin")
  statusPernikahan      String?  @map("status_pernikahan")
  pendidikan            String?
  kelas                 String?
  namaLembagaPendidikan String?  @map("nama_lembaga_pendidikan")
  dapukan               String?
  kategori              String?
  kategoriUsia          String?  @map("kategori_usia")
  golonganDarah         String?  @map("golongan_darah")
  kemubalighan          String?
  sheet                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([desa])
  @@index([sheet])
  @@index([kategoriUsia])
  @@map("census")
}

// ============================================
// FINANCIAL DASHBOARD MODELS
// ============================================

model Fund {
  id               String                 @id @default(uuid())
  name             String
  type             FundType
  color            String                 @default("#10b981")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  fromTransactions FinancialTransaction[] @relation("FromFund")
  toTransactions   FinancialTransaction[] @relation("ToFund")

  @@index([type])
  @@map("funds")
}

model FinancialTransaction {
  id          String          @id @default(uuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  category    String
  description String?
  date        DateTime        @default(now())
  fundId      String          @map("fund_id")
  fund        Fund            @relation("FromFund", fields: [fundId], references: [id])
  toFundId    String?         @map("to_fund_id")
  toFund      Fund?           @relation("ToFund", fields: [toFundId], references: [id])
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([date])
  @@index([fundId])
  @@map("financial_transactions")
}

model BudgetTarget {
  id        String   @id @default(uuid())
  category  String
  month     Int
  year      Int
  amount    Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([category, month, year])
  @@map("budget_targets")
}

enum FundType {
  reksa_dana
  emas
  e_wallet
  rekening

  @@map("fund_type")
}

enum TransactionType {
  income
  expense
  transfer

  @@map("transaction_type")
}
